# MotherMind — Environment Variables
# Copy this file to .env.local and fill in your keys
# IMPORTANT: Never put real keys in this file — it is committed to git

# Required: Google Gemini API key
# Get one at https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ElevenLabs API key
# Get one at https://elevenlabs.io
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Conversational AI Agent ID (required for voice conversations)
# Setup steps:
#   1. Go to https://elevenlabs.io/app/conversational-ai
#   2. Click "Create Agent" — name it anything (e.g. "MotherMind")
#   3. Under Security → enable "Allow client tool calls" and "Allow overrides"
#   4. Copy the Agent ID here
VITE_ELEVENLABS_AGENT_ID=your_agent_id_here
